{
  "name": "rating-ui-react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=24.18.0 <25.0.0",
    "npm": ">=11.16.0 <12.0.0"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "vite",
    "build": "run-p --aggregate-output type-check lint format build-only",
    "type-check": "tsc --build",
    "lint:js": "eslint .",
    "lint:js:fix": "eslint . --fix",
    "lint:scss": "stylelint \"src/**/*.scss\"",
    "lint:scss:fix": "stylelint \"src/**/*.scss\" --fix strict",
    "lint": "run-p --aggregate-output lint:js lint:scss",
    "lint:fix": "run-p --aggregate-output lint:js:fix lint:scss:fix",
    "format": "prettier --check src/",
    "format:fix": "prettier --write src/",
    "build-only": "vite build",
    "preview": "vite preview",
    "commit": "commit"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "focus-trap-react": "11.0.4",
    "react": "19.1.1",
    "react-dom": "19.1.1"
  },
  "devDependencies": {
    "@commitlint/cli": "19.8.1",
    "@commitlint/config-conventional": "19.8.1",
    "@commitlint/prompt-cli": "19.8.1",
    "@eslint/js": "9.36.0",
    "@types/node": "24.6.0",
    "@types/react": "19.1.16",
    "@types/react-dom": "19.1.9",
    "@vitejs/plugin-react": "5.0.4",
    "eslint": "9.36.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.22",
    "globals": "16.4.0",
    "husky": "9.1.7",
    "lint-staged": "16.1.5",
    "npm-run-all2": "8.0.4",
    "prettier": "3.6.2",
    "sass-embedded": "1.90.0",
    "stylelint": "16.23.1",
    "stylelint-config-recess-order": "7.2.0",
    "stylelint-config-standard-scss": "15.0.1",
    "stylelint-order": "7.0.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.45.0",
    "vite": "7.3.6"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.scss": [
      "stylelint --fix strict",
      "prettier --write"
    ],
    "!(src/**/*.{ts,tsx,scss})": "prettier --write --ignore-unknown"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "@parcel/watcher@2.5.1": true,
    "fsevents@2.3.3": true
  }
}
